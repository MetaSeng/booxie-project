# Gemini API Key for AI features
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# Demo mode is enabled by default only in local development.
# Set to true only if you intentionally want guest/demo access.
VITE_ENABLE_DEMO_MODE=false
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD=
VITE_DEMO_NAME=Alex (Demo)

